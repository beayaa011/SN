import requests
from requests_oauthlib import OAuth1

url = "https://api.twitter.com/2/users/me"

auth = OAuth1(
    "API_KEY",
    "API_SECRET",
    "ACCESS_TOKEN",
    "ACCESS_SECRET"
)

res = requests.get(url, auth=auth)

if res.ok:
    data = res.json()["data"]
    print(data["id"], data["username"])
else:
    print("Error:", res.status_code)
